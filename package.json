{
  "name": "carole-personal-site",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "dev:site": "vite",
    "cms:seed": "node --env-file=.env.local scripts/seed-supabase.mjs",
    "cms:backfill": "node --env-file=.env.local scripts/backfill-cms-content.mjs",
    "cms:sync-i18n": "node --env-file=.env.local scripts/sync-cms-from-i18n.mjs",
    "cms:export": "node --env-file=.env.local scripts/export-cms.mjs",
    "cms:reset": "node --env-file=.env.local scripts/reset-cms.mjs",
    "cms:media:cleanup": "node --env-file=.env.local scripts/cleanup-cms-media.mjs",
    "cms:trash:cleanup": "node --env-file=.env.local scripts/cleanup-cms-trash.mjs",
    "cms:verify": "node --env-file=.env.local scripts/verify-dashboard.mjs",
    "playwright:install": "playwright install chromium",
    "cms:preview": "node --env-file=.env.local scripts/open-preview.mjs",
    "worker:deploy": "npx wrangler deploy --config cloudflare/translate-worker/wrangler.jsonc",
    "worker:dev": "npx wrangler dev --config cloudflare/translate-worker/wrangler.jsonc",
    "security:scan": "node scripts/check-secrets.mjs",
    "security:install-hooks": "node scripts/install-hooks.mjs",
    "typecheck": "tsc --noEmit",
    "test:unit": "node --experimental-strip-types --test tests/*.test.ts"
  },
  "dependencies": {
    "@calcom/embed-react": "^1.5.3",
    "@chenglou/pretext": "^0.0.8",
