    "playwright": "^1.60.0",
    "tailwindcss": "4.1.12",
    "typescript": "^6.0.2",
    "vite": "6.3.5"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
