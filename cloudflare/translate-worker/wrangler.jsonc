{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "carole-portfolio-translate",
  "main": "src/index.js",
  "compatibility_date": "2026-05-24",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
