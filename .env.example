# --- Supabase (nouveau CMS / dashboard) ------------------------------------
# Quand ces deux variables sont renseignées, le dashboard /dashboard utilise
# Supabase (auth + données réelles). Sinon il reste en mode démo (localStorage).
# Project Settings > API :
#   - VITE_SUPABASE_URL          = "Project URL"
#   - VITE_SUPABASE_PUBLISHABLE_KEY = clé "Publishable" (sb_publishable_...)
#     (c'est la nouvelle clé recommandée, sans danger côté navigateur avec RLS ;
#      elle remplace l'ancienne clé "anon")
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Compte dashboard (Supabase Auth) — utilisé par npm run cms:seed / cms:verify
# Ne jamais committer les vraies valeurs ; les mettre uniquement dans .env.local
CMS_SEED_EMAIL=
# Guillemets obligatoires si le mot de passe contient # ou des espaces
CMS_SEED_PASSWORD=

# Optionnel : URL du dev server pour la vérif Playwright (défaut http://127.0.0.1:5173)
DASHBOARD_URL=
# Optionnel : page unique à ouvrir après vérif (défaut /dashboard)
CMS_OPEN_PATH=
# Navigateur de preview : agent (navigateur intégré de l'outil, défaut) | system (Safari/Chrome)
BROWSER_TARGET=agent

# Optional: enables the "Traduire" buttons for FR -> EN editorial fields.
# Preferred safe mode: call the protected Cloudflare Worker.
CLOUDFLARE_TRANSLATE_WORKER_URL=
TRANSLATE_WORKER_TOKEN=

# Local-only fallback for temporary debugging. Do not enable in production.
ALLOW_DIRECT_OPENAI_TRANSLATION=false
OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-4o-mini
CLOUDFLARE_AI_GATEWAY_TOKEN=
